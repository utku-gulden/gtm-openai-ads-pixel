/**
 * OpenAI Ads Measurement Pixel. Google Tag Manager Custom Template.
 *
 * Implements ONLY what is documented at:
 *   https://developers.openai.com/ads/measurement-pixel
 *
 * SDK semantics from the docs:
 *   oaiq("init", { pixelId })
 *   oaiq("measure", eventName, eventProps, eventOptions)
 *
 * Notes:
 *   - amount and quantity must be integers in the lowest denomination.
 *   - contents[] items support: id, name, content_type, quantity, amount, currency.
 *   - custom_event_name and event_id go in eventOptions, NOT eventProps.
 *   - GTM sandboxed JS does not support try/catch. We rely on queryPermission
 *     pre-checks plus defensive validators.
 */

const log = require('logToConsole');
const injectScript = require('injectScript');
const createArgumentsQueue = require('createArgumentsQueue');
const callInWindow = require('callInWindow');
const copyFromWindow = require('copyFromWindow');
const queryPermission = require('queryPermission');
const makeInteger = require('makeInteger');
const makeString = require('makeString');
const Object = require('Object');
const getType = require('getType');
const templateStorage = require('templateStorage');

const SDK_URL = 'https://bzrcdn.openai.com/sdk/oaiq.min.js';
const LOG_PREFIX = '[OpenAI Ads Pixel]';

// Standard event name → required eventProps.type per the OpenAI docs.
const EVENT_TYPE_MAP = {
  page_viewed: 'contents',
  contents_viewed: 'contents',
  items_added: 'contents',
  checkout_started: 'contents',
  order_created: 'contents',
  lead_created: 'customer_action',
  registration_completed: 'customer_action',
  appointment_scheduled: 'customer_action',
  subscription_created: 'plan_enrollment',
  trial_started: 'plan_enrollment',
  custom: 'custom'
};

const STANDARD_EVENT_NAMES = [
  'appointment_scheduled', 'checkout_started', 'contents_viewed',
  'custom', 'items_added', 'lead_created', 'order_created',
  'page_viewed', 'registration_completed', 'subscription_created',
  'trial_started'
];

// ---------------------------------------------------------------------------
// Logging. Uses explicit varargs to avoid Function.prototype.apply.
// ---------------------------------------------------------------------------
function logDebug(a, b, c, d, e) {
  // Debug logging disabled. Errors still go through logError below.
}

function logError(a, b, c) {
  if (a === undefined) { log(LOG_PREFIX, 'ERROR'); return; }
  if (b === undefined) { log(LOG_PREFIX, 'ERROR:', a); return; }
  if (c === undefined) { log(LOG_PREFIX, 'ERROR:', a, b); return; }
  log(LOG_PREFIX, 'ERROR:', a, b, c);
}

// ---------------------------------------------------------------------------
// Tiny type helpers
// ---------------------------------------------------------------------------
function isDefined(v) { return v !== undefined && v !== null && v !== ''; }

// ---------------------------------------------------------------------------
// Validators
// ---------------------------------------------------------------------------
function validatePixelId(id) {
  if (!isDefined(id)) return false;
  const s = makeString(id);
  return s.length > 0 && s.length <= 128;
}

function isValidCurrency(c) {
  if (!isDefined(c)) return false;
  const s = makeString(c);
  if (s.length !== 3) return false;
  for (let i = 0; i < 3; i++) {
    const ch = s.charAt(i);
    if (!(ch >= 'A' && ch <= 'Z')) return false;
  }
  return true;
}

function isValidCustomEventName(name) {
  if (!isDefined(name)) return false;
  const s = makeString(name);
  if (s.length < 1 || s.length > 64) return false;
  for (let i = 0; i < STANDARD_EVENT_NAMES.length; i++) {
    if (STANDARD_EVENT_NAMES[i] === s) return false;
  }
  for (let j = 0; j < s.length; j++) {
    const ch = s.charAt(j);
    const ok = (ch >= 'a' && ch <= 'z') ||
               (ch >= '0' && ch <= '9') ||
               ch === '_' || ch === '-';
    if (!ok) return false;
  }
  return true;
}

// ---------------------------------------------------------------------------
// contents[] builder. Three modes from the UI:
//   single   -> wrap the flat fields into [item]
//   multiple -> coerce each element of a user-supplied array
//   none     -> return null (do not emit contents)
// ---------------------------------------------------------------------------
function normalizeContentItem(it) {
  if (!it || getType(it) !== 'object') return null;
  const item = {};
  if (isDefined(it.id)) item.id = makeString(it.id);
  if (isDefined(it.name)) item.name = makeString(it.name);
  if (isDefined(it.content_type)) item.content_type = makeString(it.content_type);
  if (isDefined(it.quantity)) {
    const q = makeInteger(it.quantity);
    if (q === q) item.quantity = q;
  }
  if (isDefined(it.amount)) {
    const a = makeInteger(it.amount);
    if (a === a) item.amount = a;
  }
  if (isDefined(it.currency)) {
    item.currency = makeString(it.currency).toUpperCase();
  }
  // Require a meaningful anchor field. Defaults like content_type='product'
  // and quantity=1 alone are not enough to count as real content.
  if (!item.id && !item.name && item.amount === undefined) return null;
  return item;
}

function buildContents() {
  const mode = data.contentsMode || 'single';

  if (mode === 'none') return null;

  if (mode === 'multiple') {
    const v = data.contentsVariable;
    if (!isDefined(v)) return null;
    if (getType(v) !== 'array') {
      logError('Contents variable must resolve to an array. Got:', getType(v));
      return null;
    }
    const out = [];
    for (let i = 0; i < v.length; i++) {
      const norm = normalizeContentItem(v[i]);
      if (norm) out.push(norm);
    }
    return out.length ? out : null;
  }

  // mode === 'single'
  const single = normalizeContentItem({
    id: data.contentId,
    name: data.contentName,
    content_type: data.contentType,
    quantity: data.contentQuantity,
    amount: data.contentAmount,
    currency: data.contentCurrency
  });
  return single ? [single] : null;
}

// ---------------------------------------------------------------------------
// SDK lifecycle (idempotent: SDK injected once, each pixelId initialized once)
// ---------------------------------------------------------------------------
function ensureQueue() {
  if (!queryPermission('access_globals', 'read', 'oaiq')) {
    logError('access_globals (read) permission missing for oaiq.');
    return false;
  }
  const existing = copyFromWindow('oaiq');
  if (existing) {
    logDebug('oaiq already exists on window.');
    return true;
  }
  if (!queryPermission('access_globals', 'readwrite', 'oaiq') ||
      !queryPermission('access_globals', 'readwrite', 'oaiq.q')) {
    logError('access_globals (readwrite) permission missing for oaiq or oaiq.q.');
    return false;
  }
  createArgumentsQueue('oaiq', 'oaiq.q');
  logDebug('oaiq queue created.');
  return true;
}

function ensureSdkInjected(onComplete) {
  const KEY = 'sdk_injected';
  if (templateStorage.getItem(KEY)) {
    logDebug('SDK injection already requested.');
    onComplete();
    return;
  }
  if (!queryPermission('inject_script', SDK_URL)) {
    logError('Missing inject_script permission for', SDK_URL);
    data.gtmOnFailure();
    return;
  }
  templateStorage.setItem(KEY, true);
  injectScript(
    SDK_URL,
    function () { logDebug('SDK loaded successfully.'); },
    function () { logError('SDK failed to load:', SDK_URL); },
    'oaiq_sdk_v1'
  );
  logDebug('injectScript called for', SDK_URL);
  // The SDK is async, but oaiq() calls are queued, so we proceed.
  onComplete();
}

function ensurePixelInitialized(pixelId) {
  const initKey = 'init_' + pixelId;
  if (templateStorage.getItem(initKey)) {
    logDebug('Pixel already initialized for', pixelId);
    return;
  }
  if (!queryPermission('access_globals', 'execute', 'oaiq')) {
    logError('access_globals (execute) permission missing for oaiq.');
    return;
  }
  callInWindow('oaiq', 'init', { pixelId: pixelId });
  templateStorage.setItem(initKey, true);
  logDebug('Pixel initialized:', pixelId);
}

// ---------------------------------------------------------------------------
// Event resolution
// ---------------------------------------------------------------------------
function resolveEventName() {
  if (data.eventNameType === 'custom') {
    return makeString(data.customEventName || '');
  }
  return makeString(data.standardEventName || 'page_viewed');
}

function resolveEventDataType(eventName) {
  if (data.eventNameType === 'custom') {
    return data.eventDataType || 'custom';
  }
  return EVENT_TYPE_MAP[eventName] || 'custom';
}

function buildEventPayload(eventName, eventDataType) {
  const props = { type: eventDataType };

  if (isDefined(data.amount)) {
    const a = makeInteger(data.amount);
    if (a === a) props.amount = a;
  }
  if (isDefined(data.currency)) {
    props.currency = makeString(data.currency).toUpperCase();
  }
  if (isDefined(data.planId)) {
    props.plan_id = makeString(data.planId);
  }

  const contents = buildContents();
  if (contents) props.contents = contents;

  // Validation: amount requires currency.
  if (props.amount !== undefined && !props.currency) {
    logDebug('Warning: amount without currency. Dropping amount to keep payload valid.');
    props.amount = undefined;
  }
  // Validation: currency must be ISO 4217-shaped.
  if (props.currency && !isValidCurrency(props.currency)) {
    logDebug('Warning: currency does not look like ISO 4217:', props.currency);
  }

  // Strip undefined values from standard fields.
  const cleanProps = {};
  const propKeys = Object.keys(props);
  for (let j = 0; j < propKeys.length; j++) {
    if (props[propKeys[j]] !== undefined) cleanProps[propKeys[j]] = props[propKeys[j]];
  }

  // Merge custom parameters last. Standard fields win on key conflict.
  const rows = data.customParameters || [];
  for (let k = 0; k < rows.length; k++) {
    const row = rows[k];
    if (!row) continue;
    const cKey = makeString(row.key || '').trim();
    if (!cKey) continue;
    if (Object.keys(cleanProps).indexOf(cKey) !== -1) continue;
    cleanProps[cKey] = row.value;
  }

  return cleanProps;
}

function buildEventOptions(customEventName) {
  const opts = {};
  if (isDefined(data.eventId)) opts.event_id = makeString(data.eventId);
  if (customEventName) opts.custom_event_name = customEventName;
  return Object.keys(opts).length ? opts : undefined;
}

// ---------------------------------------------------------------------------
// Main flow
// ---------------------------------------------------------------------------
function fire() {
  if (!validatePixelId(data.pixelId)) {
    logError('Pixel ID is required.');
    data.gtmOnFailure();
    return;
  }
  const pixelId = makeString(data.pixelId);
  logDebug('fire() called. pixelId=', pixelId);

  if (!ensureQueue()) {
    data.gtmOnFailure();
    return;
  }

  ensureSdkInjected(function () {
    ensurePixelInitialized(pixelId);

    const eventName = resolveEventName();
    if (!eventName) {
      logError('Event name is required.');
      data.gtmOnFailure();
      return;
    }

    let customEventName;
    if (data.eventNameType === 'custom') {
      if (!isValidCustomEventName(eventName)) {
        logError('Invalid custom event name. Use 1 to 64 characters: lowercase a-z, 0-9, underscore or hyphen, and do not reuse a standard event name.');
        data.gtmOnFailure();
        return;
      }
      customEventName = eventName;
    }

    const eventDataType = resolveEventDataType(eventName);
    const eventProps = buildEventPayload(eventName, eventDataType);
    const eventOptions = buildEventOptions(customEventName);

    logDebug('measure ->', eventName, eventProps, eventOptions || {});

    if (!queryPermission('access_globals', 'execute', 'oaiq')) {
      logError('access_globals (execute) permission missing for oaiq.');
      data.gtmOnFailure();
      return;
    }
    if (eventOptions) {
      callInWindow('oaiq', 'measure', eventName, eventProps, eventOptions);
    } else {
      callInWindow('oaiq', 'measure', eventName, eventProps);
    }

    data.gtmOnSuccess();
  });
}

fire();


